DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal

DB_ENGINE=postgres
POSTGRES_DB=judge_vortex_db
POSTGRES_USER=vortex_admin
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

REDIS_CACHE_URL=redis://127.0.0.1:6379/1
CHANNEL_REDIS_HOST=127.0.0.1
CHANNEL_REDIS_PORT=6379

KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_SUBMISSIONS_TOPIC_PARTITIONS=8

EXECUTOR_BACKEND=isolate
EXECUTOR_MAX_CONCURRENCY=2
EXECUTOR_MEMORY_BYTES=268435456
EXECUTOR_COMPILE_MEMORY_BYTES=536870912
EXECUTOR_MAX_OUTPUT_KB=1024
ISOLATE_BOXES=32

EXECUTOR_CORE_REPLICAS=1
EXECUTOR_JAVA_REPLICAS=1
EXECUTOR_MAX_DELIVERY_ATTEMPTS=3
KAFKA_DEAD_LETTER_TOPIC=code_submissions_dead_letter

ENABLE_EXECUTOR_AUTOSCALER=0
AUTOSCALER_INTERVAL_SECONDS=15
AUTOSCALER_LAG_PER_REPLICA=12
AUTOSCALER_COOLDOWN_SECONDS=30
AUTOSCALER_MIN_REPLICAS_CORE=1
AUTOSCALER_MAX_REPLICAS_CORE=4
AUTOSCALER_MIN_REPLICAS_JAVA=1
AUTOSCALER_MAX_REPLICAS_JAVA=3

CONFIG_CONTROL_BASE_URL=
CONFIG_CONTROL_RUNTIME_CONFIG_NAME=judge-vortex.runtime
CONFIG_CONTROL_ENVIRONMENT=prod
CONFIG_CONTROL_TARGET=judge-vortex
CONFIG_CONTROL_CLIENT_ID=judge-vortex-web
CONFIG_CONTROL_USER_ID=judge-vortex
CONFIG_CONTROL_ROLE=reader
CONFIG_CONTROL_TIMEOUT_SECONDS=0.75
CONFIG_CONTROL_CACHE_TTL_SECONDS=15

RATE_LIMITER_BASE_URL=
RATE_LIMITER_SERVICE_TOKEN=
RATE_LIMITER_TIMEOUT_MS=500
RATE_LIMITER_FAIL_OPEN=1

GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_BASE=
